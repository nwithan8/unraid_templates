<?xml version="1.0"?>
<Container version="2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://raw.githubusercontent.com/nwithan8/unraid_templates/main/templates/template_schema.xsd template_schema.xsd">
    <Name>Tater</Name>
    <Repository>ghcr.io/tatertotterson/tater:latest</Repository>
    <Registry>https://github.com/TaterTotterson/Tater/pkgs/container/tater</Registry>
    <Branch>
        <Tag>latest</Tag>
        <TagDescription>Latest stable release</TagDescription>
    </Branch>
    <Network>host</Network>
    <WebUI>http://[IP]:[PORT:8501]/</WebUI>
    <Shell>sh</Shell>
    <Privileged>false</Privileged>
    <Support>https://github.com/TaterTotterson/Tater/issues</Support>
    <Project>https://github.com/TaterTotterson/Tater</Project>
    <Overview>
        A Local AI LLM Assistant With Tools and Integrations for Home Assistant, HomeKit, XBMC, Discord, Matrix, IRC, and Automations
    </Overview>
    <Beta>False</Beta>
    <Category>AI: HomeAutomation: Productivity: Tools: Other: Status:Stable</Category>
    <ExtraSearchTerms>ai llm local assistant home assistant homekit xbmc discord matrix irc automations tools integrations productivity tatertotterson tater</ExtraSearchTerms>
    <Icon>https://raw.githubusercontent.com/tatertotterson/Tater/refs/heads/main/images/tater.png</Icon>
    <TemplateURL>https://raw.githubusercontent.com/nwithan8/unraid_templates/main/templates/tater.xml</TemplateURL>
    <Maintainer>
        <WebPage>https://github.com/nwithan8</WebPage>
    </Maintainer>
    <Changes>
        ### 2026-04-19

        - Move to host network
        - Update paths

        ### 2026-01-22

        Initial release
    </Changes>
    <Requires>
        Requires a separate OpenAI-compatible LLM instance and Redis instance.
    </Requires>
    <Config Name="Agent Lab Config" Target="/app/agent_lab" Default="/mnt/user/appdata/tater/agent_lab" Description="Path to the Agent Lab config data" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/tater/agent_lab</Config>
    <Config Name="Runtime" Target="/app/.runtime" Default="/mnt/user/appdata/tater/runtime" Description="Path to the runtime data" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/tater/runtime</Config>
</Container>
