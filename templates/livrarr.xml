    <Project>https://github.com/kkodecs/livrarr</Project>
    <Overview>
        Self-hosted ebook and audiobook library manager. Built for the *arr ecosystem — finds, grabs, and organizes your books
    </Overview>
    <Beta>True</Beta>
    <Category>Downloaders: MediaApp:Other Productivity: Tools: Other: Status:Stable</Category>
    <ExtraSearchTerms>automation download sonarr radarr readarr lidarr books ebooks audiobooks comics</ExtraSearchTerms>
    <Icon>https://raw.githubusercontent.com/nwithan8/unraid_templates/master/images/livrarr-icon.png</Icon>
    <TemplateURL>https://raw.githubusercontent.com/nwithan8/unraid_templates/main/templates/livrarr.xml</TemplateURL>
    <Maintainer>
        <WebPage>https://github.com/nwithan8</WebPage>
    </Maintainer>
    <Changes>
        ### 2026-06-27

        Initial release
    </Changes>
    <Config Name="Web UI Port" Target="8789" Default="8789" Mode="tcp" Description="Container Port: 8789" Type="Port" Display="always-hide" Required="true" Mask="false">8789</Config>
    <Config Name="Books Storage" Target="/books" Default="" Description="Path to books storage" Type="Path" Display="always-hide" Required="true" Mask="false"/>
    <Config Name="Downloads Storage" Target="/downloads" Default="" Description="Path to downloads storage" Type="Path" Display="always-hide" Required="true" Mask="false"/>
    <Config Name="Config Data" Target="/config" Default="/mnt/user/appdata/livrarr/config" Description="Path to the config data" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/livrarr/config</Config>
    <Config Name="PUID" Target="PUID" Default="99" Description="Container User ID" Type="Variable" Display="advanced-hide" Required="true" Mask="false">99</Config>
    <Config Name="PGID" Target="PGID" Default="100" Description="Container Group ID" Type="Variable" Display="advanced-hide" Required="true" Mask="false">100</Config>
</Container>
