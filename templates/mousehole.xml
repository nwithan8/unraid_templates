<?xml version="1.0"?>
<Container version="2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://raw.githubusercontent.com/nwithan8/unraid_templates/main/templates/template_schema.xsd template_schema.xsd">
    <Name>Mousehole</Name>
    <Repository>t-mart/mousehole:latest</Repository>
    <Registry>https://hub.docker.com/r/tmmrtn/mousehole</Registry>
    <Branch>
        <Tag>latest</Tag>
        <TagDescription>Latest stable release</TagDescription>
    </Branch>
    <Network>bridge</Network>
    <WebUI>http://[IP]:[PORT:5010]/</WebUI>
    <Privileged>false</Privileged>
    <Support>https://github.com/t-mart/mousehole/issues</Support>
    <Project>https://github.com/t-mart/mousehole</Project>
    <Overview>
        A background service to update a seedbox IP for MAM and an HTTP server to manage it.
    </Overview>
    <Beta>False</Beta>
    <Category>Downloaders: Productivity: Tools: Other: Status:Stable</Category>
    <ExtraSearchTerms>seedbox mam dynamic ip updater dyndns torrent</ExtraSearchTerms>
    <Icon>https://raw.githubusercontent.com/nwithan8/unraid_templates/master/images/mousehole-icon.png</Icon>
    <TemplateURL>https://raw.githubusercontent.com/nwithan8/unraid_templates/main/templates/mousehole.xml</TemplateURL>
    <Screenshot>https://raw.githubusercontent.com/t-mart/mousehole/master/docs/demo.webp</Screenshot>
    <Maintainer>
        <WebPage>https://github.com/nwithan8</WebPage>
    </Maintainer>
    <Changes>
        ### 2026-06-07

        Update variables

        ### 2025-10-25

        Initial release
    </Changes>
    <Config Name="Web UI Port" Target="5010" Default="5010" Mode="tcp" Description="Container Port: 5010" Type="Port" Display="always-hide" Required="true" Mask="false">5010</Config>
    <Config Name="Auth Password" Target="MOUSEHOLE_AUTH_PASSWORD" Default="" Description="Password for Mousehole web UI, API, and WebSocket authentication" Type="Variable" Display="always-hide" Required="true" Mask="true"/>
    <Config Name="Allowed Hosts" Target="MOUSEHOLE_ALLOWED_HOSTS" Default="" Description="Comma-separated hostnames or IP addresses allowed to access Mousehole, such as your Unraid server IP or hostname. Set this when opening the WebUI through http://[IP]:5010." Type="Variable" Display="always" Required="false" Mask="false"/>
    <Config Name="App Data" Target="/var/lib/mousehole" Default="/mnt/user/appdata/mousehole/data" Description="Path to the data folder" Type="Path" Display="advanced-hide" Required="true" Mask="false">/mnt/user/appdata/mousehole/data</Config>
    <Config Name="PUID" Target="PUID" Default="099" Description="" Type="Variable" Display="advanced" Required="true" Mask="false">099</Config>
    <Config Name="PGID" Target="PGID" Default="100" Description="" Type="Variable" Display="advanced" Required="true" Mask="false">100</Config>
    <Config Name="UMASK" Target="UMASK" Default="022" Description="" Type="Variable" Display="advanced" Required="false" Mask="false">022</Config>
</Container>
